ENV=development
FRONTEND_URL=http://localhost:5500
# Public URL of THIS backend service (used in emailed download links).
# On Railway, set this to your actual Railway service URL, e.g.
# https://resume-builder-backend-production-413e.up.railway.app
BACKEND_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/resume_builder
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
STORAGE_BUCKET=resumes
STORAGE_ENDPOINT_URL=https://xxx.supabase.co/storage/v1
STORAGE_ACCESS_KEY=xxx
STORAGE_SECRET_KEY=xxx
DOWNLOAD_LINK_SECRET=generate-a-long-random-string
DOWNLOAD_LINK_EXPIRY_MINUTES=15
EMAIL_FROM_ADDRESS=your-email-address
EMAIL_APP_PASSWORD=xxxxxxxxx